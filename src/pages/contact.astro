---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <section class="bg-brand-950 text-white">
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
      <div class="flex flex-col-reverse md:flex-row md:items-center md:justify-between md:gap-12">
        <div>
          <h1 class="font-display text-4xl md:text-5xl mb-4">Get in Touch</h1>
          <p class="text-slate-300 text-lg max-w-2xl">
            Open to Technical Sales, Enterprise Account Manager, and Technical CSM opportunities in the Bay Area and remote.
          </p>
        </div>
        <img src="/contact.jpg" alt="Ramilya Bakiyeva" class="w-40 h-40 md:w-72 md:h-72 rounded-full object-cover border-4 border-brand-800 shadow-xl mb-8 md:mb-0 shrink-0" />
      </div>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6 py-16">
    <!-- Direct contact -->
    <div class="space-y-6 mb-16">
      <a href="mailto:hello@ramilya.tech"
         class="flex items-center gap-4 p-5 rounded-xl border border-slate-200 hover:border-brand-300 hover:shadow-md transition-all group">
        <div class="w-12 h-12 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <p class="font-medium text-brand-900 group-hover:text-brand-700 transition-colors">Email</p>
          <p class="text-sm text-slate-500">hello@ramilya.tech</p>
        </div>
      </a>

      <a href="https://www.linkedin.com/in/ramilyabakiyeva/" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-4 p-5 rounded-xl border border-slate-200 hover:border-brand-300 hover:shadow-md transition-all group">
        <div class="w-12 h-12 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div>
          <p class="font-medium text-brand-900 group-hover:text-brand-700 transition-colors">LinkedIn</p>
          <p class="text-sm text-slate-500">linkedin.com/in/ramilyabakiyeva</p>
        </div>
      </a>

      <a href="https://github.com/ramilyabm" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-4 p-5 rounded-xl border border-slate-200 hover:border-brand-300 hover:shadow-md transition-all group">
        <div class="w-12 h-12 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-brand-600" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <div>
          <p class="font-medium text-brand-900 group-hover:text-brand-700 transition-colors">GitHub</p>
          <p class="text-sm text-slate-500">github.com/ramilyabm</p>
        </div>
      </a>
    </div>

    <!-- Contact form -->
    <div class="border-t border-slate-200 pt-12">
      <h2 class="font-display text-2xl text-brand-900 mb-6">Send a Message</h2>
      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Name</label>
          <input type="text" id="name" name="name" required
                 class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" id="email" name="email" required
                 class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-slate-700 mb-1">Message</label>
          <textarea id="message" name="message" rows="5" required
                    class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all resize-y"></textarea>
        </div>
        <button type="submit"
                class="bg-brand-700 hover:bg-brand-800 text-white font-medium px-6 py-3 rounded-lg transition-colors">
          Send Message
        </button>
      </form>
      <p class="text-xs text-slate-400 mt-4">
        Form powered by Formspree (free tier). No backend required.
      </p>
    </div>
  </section>
</Layout>
